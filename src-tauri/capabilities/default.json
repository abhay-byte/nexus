{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the Nexus desktop window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "dialog:default",
    "fs:default",
    "shell:default",
    "shell:allow-open",
    "fs:allow-mkdir",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-write",
    "fs:allow-create",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPCONFIG/**" }, { "path": "**" }]
    }
  ]
}
